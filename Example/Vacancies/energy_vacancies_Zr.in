#!/root/bin/lmp

# Initialization
units metal
dimension 3
boundary p p p
atom_style atomic

# Create hcp lattice
# lattice custom 3.231 a1 1 0 0 a2 0 1.73205 0 a3 0 0 1.5926 basis 0 0 0 basis 0.5 0.5 0 basis 0.5 0.25 0.5 basis 0 0.75 0.5 orient x 1 0 0 orient y 0 1 0 orient z 0 0 1
lattice hcp 3.231

region box block 0 20 0 10 0 10
create_box 1 box
create_atoms 1 box

# Define potential
pair_style eam/fs
pair_coeff * * ../Zr_3.eam.fs Zr

mass 1 91.224

# Define thermodynamics
thermo 100
thermo_style custom step temp press pe ke etotal lx ly lz

#---------------------------Settings----------------------------
compute csym all centro/atom 12
compute eng all pe/atom
compute eatoms all reduce sum c_eng
#compute cnad all cna/atom 4.4663
#----------------------Run Minimization-------------------------

reset_timestep  0

thermo 100
thermo_style custom step pe lx ly lz press pxx pyy pzz c_eatoms vol cpuremain
thermo_modify lost warn flush yes
dump 1 all custom 10 Zr_vac.dump id type xs ys zs c_csym c_eng

min_style cg
minimize 1e-15 1e-15 10000 10000

#variable N equal count(all), counts the total number of atoms in the cell
#the total number of atoms is stored to the variable N
variable N equal count(all)
variable No equal $N

#variable Ei equal "c_eatoms" computes the initial energy of the cell system before the vacancy
#E is needed to store the initial energy of the system to the variable Ei
variable E equal c_eatoms
variable E0 equal $E

#group pointdefect id #POINT_DEFECT_ID#
##group pointdefect id 100
#delete_atoms group pointdefect compress yes

group group_Zr type 1
delete_atoms random count 1 no group_Zr NULL 100
# group vac id 1
# delete_atoms group vac

#group sub_freeze id <= ${No}
fix 1 all setforce 0.0 0.0 0.0

min_style cg
minimize 1e-15 1e-15 10000 10000

variable Ef equal "c_eatoms"
variable Ev equal (${Ef}-((${No}-1)/${No})*${E0})
variable Ec equal (-${E0}/${No})

#---------------------------------------------

######################################
# SIMULATION DONE
print "All done"
print "Total number of atoms = ${No}"
print "Initial energy of atoms = ${E0}"
print "Final energy of atoms = ${Ef}"
print "Vacancy formation energy = ${Ev}"
print "Cohesion energy = ${Ec}"
shell echo Vacancy formation energy = ${Ev} eV >>Ev_Zr

